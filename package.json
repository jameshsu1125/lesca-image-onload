{
  "name": "lesca-image-onload",
  "description": "a listener of css background image onload",
  "private": false,
  "version": "4.1.2",
  "type": "module",
  "files": [
    "lib"
  ],
  "keywords": [
    "lesca",
    "images onload"
  ],
  "main": "./lib/index.cjs",
